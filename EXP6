#include <stdio.h>
#define MAX 100

struct Node
{
    int data;
    int priority;
};

struct Node heap[MAX];
int size = 0;

void swap(struct Node *a, struct Node *b)
{
    struct Node temp = *a;
    *a = *b;
    *b = temp;
}

void insert(int value, int priority)
{
    if (size == MAX)
    {
        printf("Priority Queue is full!\n");
        return;
    }

    int i = size;
    heap[size].data = value;
    heap[size].priority = priority;
    size++;

    while (i != 0 && heap[(i - 1) / 2].priority < heap[i].priority)   // Max Heap
    {
        swap(&heap[i], &heap[(i - 1) / 2]);
        i = (i - 1) / 2;
    }
}

void heapifyDown(int i)
{
    int largest = i;
    int left = 2 * i + 1;
    int right = 2 * i + 2;

    if (left < size && heap[left].priority > heap[largest].priority)
        largest = left;

    if (right < size && heap[right].priority > heap[largest].priority)
        largest = right;

    if (largest != i)
    {
        swap(&heap[i], &heap[largest]);
        heapifyDown(largest);
    }
}

void deleteHighest()
{
    if (size == 0)
    {
        printf("Priority Queue is empty!\n");
        return;
    }

    printf("Deleted Element: %d\n", heap[0].data);
    heap[0] = heap[size - 1];
    size--;
    heapifyDown(0);
}

void peek()
{
    if (size == 0)
    {
        printf("Priority Queue is empty!\n");
        return;
    }

    printf("Highest Priority Element: %d\n", heap[0].data);
}

void display()
{
    if (size == 0)
    {
        printf("Priority Queue is empty!\n");
        return;
    }

    printf("Elements in Priority Queue:\n");
    for (int i = 0; i < size; i++)
        printf("Value = %d, Priority = %d\n", heap[i].data, heap[i].priority);
}

int main()
{
    int choice, value, priority;

    while (1)
    {
        printf("\n1.Insert\n2.Delete Highest Priority\n3.Peek\n4.Display\n5.Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch (choice)
        {
            case 1:
                printf("Enter value: ");
                scanf("%d", &value);
                printf("Enter priority: ");
                scanf("%d", &priority);
                insert(value, priority);
                break;

            case 2:
                deleteHighest();
                break;

            case 3:
                peek();
                break;

            case 4:
                display();
                break;

            case 5:
                return 0;

            default:
                printf("Invalid choice!\n");
        }
    }
}
