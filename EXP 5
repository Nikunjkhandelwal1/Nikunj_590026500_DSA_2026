#include <stdio.h>
#define MAX 100

int tree[MAX];

void insert(int value, int index)
{
    if(index >= MAX)
    {
        printf("Cannot insert\n");
        return;
    }
    tree[index] = value;
}

void display(int n)
{
    int i;
    for(i = 0; i < n; i++)
    {
        if(tree[i] != -1)
            printf("%d ", tree[i]);
    }
    printf("\n");
}

void showRelations(int value, int n)
{
    int i;
    for(i = 0; i < n; i++)
    {
        if(tree[i] == value)
        {
            printf("Node: %d\n", value);

            if(i == 0)
                printf("Parent: None\n");
            else
                printf("Parent: %d\n", tree[(i - 1) / 2]);

            if(2 * i + 1 < n && tree[2 * i + 1] != -1)
                printf("Left Child: %d\n", tree[2 * i + 1]);
            else
                printf("Left Child: None\n");

            if(2 * i + 2 < n && tree[2 * i + 2] != -1)
                printf("Right Child: %d\n", tree[2 * i + 2]);
            else
                printf("Right Child: None\n");

            return;
        }
    }
    printf("Value not found\n");
}

int main()
{
    int i, n, value, choice;

    for(i = 0; i < MAX; i++)
        tree[i] = -1;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        printf("Enter value: ");
        scanf("%d", &value);
        insert(value, i);
    }

    while(1)
    {
        printf("\n1. Display Tree\n2. Show Relations\n3. Exit\n");
        scanf("%d", &choice);

        if(choice == 1)
        {
            display(n);
        }
        else if(choice == 2)
        {
            printf("Enter node value: ");
            scanf("%d", &value);
            showRelations(value, n);
        }
        else
        {
            break;
        }
    }

    return 0;
}

