#include <stdio.h>
#include <string.h>

#define MAX 100

char stack[MAX];
char queue[MAX];
int top = -1;
int front = 0, rear = -1;

void push(char c)
{
    if (top < MAX - 1)
    {
        top++;
        stack[top] = c;
    }
}

void enqueue(char c)
{
    if (rear < MAX - 1)
    {
        rear++;
        queue[rear] = c;
    }
}

char pop()
{
    if (top >= 0)
    {
        return stack[top--];
    }
    return '\0';
}

char dequeue()
{
    if (front <= rear)
    {
        return queue[front++];
    }
    return '\0';
}

int main()
{
    char str[MAX];
    int i, len, flag = 1;

    printf("Enter a string: ");
    scanf("%s", str);

    len = strlen(str);

    for (i = 0; i < len; i++)
    {
        push(str[i]);
        enqueue(str[i]);
    }

    for (i = 0; i < len; i++)
    {
        if (pop() != dequeue())
        {
            flag = 0;
            break;
        }
    }

    if (flag)
        printf("Palindrome\n");
    else
        printf("Not a Palindrome\n");

    return 0;
}

