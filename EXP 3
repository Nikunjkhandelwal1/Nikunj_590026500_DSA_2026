#include <stdio.h>
#include <ctype.h>
#include <string.h>

#define MAX 100

char stack[MAX];
int top = -1;

void push(char ch)
{
    stack[++top] = ch;
}

char pop()
{
    if (top == -1)
        return -1;
    return stack[top--];
}

char peek()
{
    if (top == -1)
        return -1;
    return stack[top];
}

int precedence(char op)
{
    if (op == '^') return 3;
    if (op == '*' || op == '/') return 2;
    if (op == '+' || op == '-') return 1;
    return 0;
}

void infixToPostfix(char infix[], char postfix[])
{
    int i, j = 0;
    char ch;

    for (i = 0; infix[i] != '\0'; i++)
    {
        ch = infix[i];

        if (isalnum(ch))
        {
            postfix[j++] = ch;
        }
        else if (ch == '(')
        {
            push(ch);
        }
        else if (ch == ')')
        {
            while (peek() != '(')
            {
                postfix[j++] = pop();
            }
            pop();
        }
        else
        {
            while (top != -1 && precedence(peek()) >= precedence(ch))
            {
                postfix[j++] = pop();
            }
            push(ch);
        }
    }

    while (top != -1)
    {
        postfix[j++] = pop();
    }

    postfix[j] = '\0';
}

int main()
{
    char infix[MAX] = "A+B*(C^D-E)^(F+G*H)-I";
    char postfix[MAX];

    infixToPostfix(infix, postfix);

    printf("Infix Expression: %s\n", infix);
    printf("Postfix Expression: %s\n", postfix);

    return 0;
}
Q6.
#include <stdio.h>
#include <ctype.h>

#define MAX 100

int stack[MAX];
int top = -1;

void push(int value)
{
    stack[++top] = value;
}

int pop()
{
    if (top == -1)
        return -1;
    return stack[top--];
}

int evaluatePostfix(char exp[])
{
    int i = 0;
    int op1, op2, result;

    while (exp[i] != '\0')
    {
        char ch = exp[i];

        if (isdigit(ch))
        {
            push(ch - '0');
        }
        else
        {
            op2 = pop();
            op1 = pop();

            switch (ch)
            {
                case '+': result = op1 + op2; break;
                case '-': result = op1 - op2; break;
                case '*': result = op1 * op2; break;
                case '/': result = op1 / op2; break;
                case '^':
                {
                    result = 1;
                    for (int j = 0; j < op2; j++)
                        result *= op1;
                    break;
                }
            }

            push(result);
        }
        i++;
    }

    return pop();
}

int main()
{
    char exp[] = "23*54*+9-";

    printf("Postfix Expression: %s\n", exp);
    printf("Result: %d\n", evaluatePostfix(exp));

    return 0;
}
