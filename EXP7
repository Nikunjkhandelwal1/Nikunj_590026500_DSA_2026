int graph[20][20], visited[20], n;

void dfs(int vertex) {
    int i;
    printf("%d ", vertex);
    visited[vertex] = 1;

    for(i = 0; i < n; i++) {
        if(graph[vertex][i] == 1 && visited[i] == 0) {
            dfs(i);
        }
    }
